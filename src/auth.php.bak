<?php
// ─── AutoSecForge Pro v12 — Authentication & RBAC ────────────────
// Fixes: ASF-005 (session hardening), ASF-007 (Argon2ID), ASF-003 (IDOR)

declare(strict_types=1);

// ASF-005: Secure session configuration
ini_set('session.cookie_httponly', '1');
ini_set('session.cookie_samesite', 'Strict');
ini_set('session.use_strict_mode', '1');
ini_set('session.gc_maxlifetime', '3600');

if (empty(session_id())) {
    session_start();
}

// ─── Database connection ──────────────────────────────────────────
function db(): PDO {
    static $pdo = null;
    if ($pdo === null) {
        $host = $_ENV['DB_HOST'] ?? 'security-dashboard-db';
        $port = $_ENV['DB_PORT'] ?? '3306';
        $name = $_ENV['DB_DATABASE'] ?? 'security_dashboard';
        $user = $_ENV['DB_USER'] ?? 'dashboard';
        $pass = $_ENV['DB_PASSWORD'] ?? '';
        $dsn  = "mysql:host={$host};port={$port};dbname={$name};charset=utf8mb4";
        $pdo  = new PDO($dsn, $user, $pass, [
            PDO::ATTR_ERRMODE            => PDO::ERRMODE_EXCEPTION,
            PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
            PDO::ATTR_EMULATE_PREPARES   => false,   // Force real prepared statements
        ]);
    }
    return $pdo;
}

// ─── Login ───────────────────────────────────────────────────────
// ASF-007: Argon2ID verification (passwords stored with PASSWORD_ARGON2ID)
function login(string $email, string $password): bool {
    $stmt = db()->prepare('SELECT id, password_hash, role, name FROM users WHERE email = ? AND active = 1 LIMIT 1');
    $stmt->execute([$email]);
    $user = $stmt->fetch();

    if (!$user || !password_verify($password, $user['password_hash'])) {
        // Constant-time delay to prevent timing attacks
        usleep(random_int(200000, 400000));
        return false;
    }

    // Rehash if algorithm has been upgraded
    if (password_needs_rehash($user['password_hash'], PASSWORD_ARGON2ID)) {
        $new = password_hash($password, PASSWORD_ARGON2ID);
        db()->prepare('UPDATE users SET password_hash = ? WHERE id = ?')->execute([$new, $user['id']]);
    }

    session_regenerate_id(true); // ASF-005: Prevent session fixation
    $_SESSION['user_id']   = $user['id'];
    $_SESSION['user_role'] = $user['role'];
    $_SESSION['user_name'] = $user['name'];
    return true;
}

// ─── Require auth ────────────────────────────────────────────────
function require_auth(): void {
    if (empty($_SESSION['user_id'])) {
        header('Location: /login.php');
        exit;
    }
}

// ─── Require role ────────────────────────────────────────────────
function require_role(string ...$allowed_roles): void {
    require_auth();
    if (!in_array($_SESSION['user_role'], $allowed_roles, true)) {
        http_response_code(403);
        die('Access denied.');
    }
}

// ─── ASF-003: IDOR Fix — enforce project membership ─────────────
// Use this on every project/finding/report page.
function user_can_access_project(int $project_id): bool {
    $uid  = (int)($_SESSION['user_id'] ?? 0);
    $role = $_SESSION['user_role'] ?? '';

    // Admins and managers see all
    if (in_array($role, ['admin', 'manager'], true)) {
        return true;
    }

    // Everyone else must be in project_members
    $stmt = db()->prepare(
        'SELECT 1 FROM project_members WHERE project_id = ? AND user_id = ? LIMIT 1'
    );
    $stmt->execute([$project_id, $uid]);
    return (bool)$stmt->fetch();
}

// ─── Logout ──────────────────────────────────────────────────────
function logout(): void {
    $_SESSION = [];
    session_destroy();
    header('Location: /login.php');
    exit;
}

// ─── Hash password (for setup/user creation) ─────────────────────
function hash_password(string $plain): string {
    return password_hash($plain, PASSWORD_ARGON2ID, [
        'memory_cost' => 65536,
        'time_cost'   => 4,
        'threads'     => 2,
    ]);
}
