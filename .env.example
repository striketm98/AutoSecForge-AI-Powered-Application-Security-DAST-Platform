# ── AutoSecForge Pro v12.1 – .env.example ────────────────────────
# Copy this to .env and fill in all CHANGE_ME_ values.
# Generate secrets: openssl rand -base64 32
# NEVER commit .env to Git.

APP_NAME=AutoSecForge
APP_ENV=production
APP_DEBUG=false
APP_URL=https://autosecforge.com

DB_HOST=db
DB_PORT=3306
DB_NAME=security_dashboard
DB_USER=dashboard
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_DB_ROOT_PASSWORD

SESSION_SECRET=CHANGE_ME_SESSION_SECRET
APP_KEY=CHANGE_ME_APP_KEY

# ZAP API Key - MANDATORY (ASF-009)
ZAP_API_KEY=CHANGE_ME_ZAP_API_KEY

# ── Ollama (local LLM) ────────────────────────────────────────────
# After first docker compose up, pull a model:
#   docker exec -it <ollama-container> ollama pull llama3
OLLAMA_MODEL=llama3

# ── Internal service URLs (Docker network) ────────────────────────
MCP_URL=http://mcp-router:6300
AI_AGENT_URL=http://ai-agent:6400
OASM_URL=http://oasm:6200
SQLMAP_URL=http://sqlmap:6000
