# ============================================================
# AutoSecForge – .env.example
#
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# Add .env to .gitignore (see below).
#
# ASF-001 / ASF-008 FIX: All credentials are now environment
# variables.  Hard-coded fallbacks in the source code have been
# removed.  If any variable is absent the application will
# refuse to start rather than use a default credential.
# ============================================================

# ---- Database ------------------------------------------------
# Use a strong random password (e.g. openssl rand -base64 32)
DB_ROOT_PASSWORD=CHANGE_ME_root_password
DB_PASSWORD=CHANGE_ME_app_password

# ---- OWASP ZAP -----------------------------------------------
# ASF-009 FIX: ZAP now requires a non-empty API key.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
ZAP_API_KEY=CHANGE_ME_zap_api_key

# ---- SonarQube -----------------------------------------------
SONAR_JDBC_URL=jdbc:postgresql://sonar-db:5432/sonarqube
SONAR_JDBC_PASSWORD=CHANGE_ME_sonar_password

# ---- Application ---------------------------------------------
APP_ENV=production
APP_SECRET=CHANGE_ME_app_secret_key
