# AutoSecForge - Railway Environment Variables
# Add these in Railway Dashboard → Variables

# Database (auto-filled by Railway MySQL plugin)
DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=security_dashboard
DB_USER=dashboard
DB_PASSWORD=your-secure-password

# App Settings
APP_NAME=AutoSecForge Pro

# Tool endpoints (optional - only if self-hosting these services)
ZAP_URL=http://localhost:8090
SONARQUBE_URL=http://localhost:9000
MCP_HACKSTRIKE_URL=http://localhost:6300
OPENAI_AGENTS_URL=http://localhost:6400
