# ── AutoSecForge Pro v12 – .env.example ─────────────────────────
# Copy this to .env and fill in all CHANGE_ME_ values.
# Generate secrets: openssl rand -base64 32
# NEVER commit .env to Git.

APP_NAME=AutoSecForge
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8080

DB_HOST=security-dashboard-db
DB_PORT=3306
DB_DATABASE=security_dashboard
DB_USER=dashboard
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_DB_ROOT_PASSWORD

SESSION_SECRET=CHANGE_ME_SESSION_SECRET
APP_KEY=CHANGE_ME_APP_KEY

# ZAP API Key - MANDATORY (ASF-009)
ZAP_API_KEY=CHANGE_ME_ZAP_API_KEY

MCP_URL=http://autosecforge-mcp-hackstrike:6300
AI_AGENT_URL=http://autosecforge-openai-free-agents:6400
PENTEST_URL=http://security-dashboard-pentest-python:6100
OASM_URL=http://security-dashboard-oasm:6200
SQLMAP_URL=http://security-dashboard-sqlmap:6000
