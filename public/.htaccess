<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # CSP lives here (volume-mounted → changes apply without image rebuild)
    # and overrides any policy baked into the vhost. Allowed CDNs are exactly
    # what the UI loads: jsdelivr (Bootstrap/AdminLTE/jQuery/Chart.js),
    # cdnjs (Font Awesome), Google Fonts (Inter).
    Header always unset Content-Security-Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com; img-src 'self' data:; connect-src 'self'; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net;"
</IfModule>

Options -Indexes

# Apache 2.4 access control (Require) only — never mix with 2.2-era
# Order/Deny/Allow here; combining both systems yields blanket 403s.

# Block .env and hidden/sensitive files from web access
<FilesMatch "(^\.env|\.env\.|\.htpasswd|\.git)">
    Require all denied
</FilesMatch>

# Block all PHP by default
<FilesMatch "\.(php|phtml)$">
    Require all denied
</FilesMatch>

# Allow known public pages
<FilesMatch "^(index|login|home|dashboard|logout|change_password|scan_trigger|scan_jobs|report|clients|checklist|audit|addons|settings|review|deliverables|oasm|export|import|mobsf|sast|ideas)\.php$">
    Require all granted
</FilesMatch>

# Allow API endpoints
<FilesMatch "^(stats|recent_scans|trigger_scan|ai_analyze|findings|ideas|notifications)\.php$">
    Require all granted
</FilesMatch>
