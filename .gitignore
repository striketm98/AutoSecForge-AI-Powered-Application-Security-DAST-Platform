# ============================================================
# AutoSecForge – .gitignore
# ASF-001 / ASF-008 FIX: Never commit secrets or uploads.
# ============================================================

# Environment / secrets
.env
*.env
secrets/
docker-secrets/

# Upload storage (outside webroot)
storage/

# Composer / npm
vendor/
node_modules/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
/tmp/

# Build artefacts
*.zip
*.tar.gz
